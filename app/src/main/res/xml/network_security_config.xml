<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 
        Network Security Configuration for DSScreen App
        This configuration allows the app to trust custom certificates
        and handle SSL/TLS connections properly.
    -->
    
    <!-- Base configuration for all connections -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system certificates (pre-installed on device) -->
            <certificates src="system" />
            <!-- Trust user-installed certificates (for debugging) -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Domain-specific configuration for your backend -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">signage.logicalvalley.in</domain>
        <trust-anchors>
            <!-- Trust system certificates -->
            <certificates src="system" />
            <!-- Trust user-installed certificates -->
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    
    <!-- Debug configuration - allows localhost and IP addresses -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Add your local IP if needed -->
        <domain includeSubdomains="true">192.168.1.1</domain>
    </domain-config>
</network-security-config>

